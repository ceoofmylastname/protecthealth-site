---
// Shared scrolling Google review wall — same look as the homepage reviews section.
// Two auto-scrolling rows of compact review cards, verbatim from the live Google listing.
// Display-only: intentionally NO AggregateRating/Review schema.
import { SITE } from '../lib/site';
import { GOOGLE_REVIEWS } from '../lib/reviews';

const rowA = GOOGLE_REVIEWS.slice(0, 10);
const rowB = GOOGLE_REVIEWS.slice(10);
---
<div class="review-wall reveal">
  {[rowA, rowB].map((row, ri) => (
    <div class={`rv-row ${ri === 1 ? 'rv-reverse' : ''}`}>
      <div class="rv-track">
        {[...row, ...row].map((r) => (
          <a class="rv-card" href={SITE.reviews.url} target="_blank" rel="noopener noreferrer" aria-label={`Google review by ${r.name}`}>
            <div class="rv-head">
              <span class="rv-avatar">
                {r.name.charAt(0)}
                {r.photo && <img src={r.photo} alt={`${r.name} on Google`} loading="lazy" referrerpolicy="no-referrer" onerror="this.remove()" />}
              </span>
              <span class="rv-meta"><b>{r.name}</b><em><span class="rv-stars">★★★★★</span> · {r.date}</em></span>
              <span class="rv-g">G</span>
            </div>
            <p class="rv-text">{r.text}</p>
          </a>
        ))}
      </div>
    </div>
  ))}
  <p class="rv-note">Real reviews, word for word, from ProtectHealth's Google listing. <a href={SITE.reviews.url} target="_blank" rel="noopener noreferrer">Read all {SITE.reviews.count}+ on Google</a>.</p>
</div>

<style>
  .review-wall { margin-top: 34px; overflow: hidden; }
  .rv-row { overflow: hidden; padding: 10px 0; -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent); mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent); }
  .rv-track { display: flex; gap: 16px; width: max-content; animation: rvScroll 55s linear infinite; }
  .rv-reverse .rv-track { animation-direction: reverse; }
  .rv-row:hover .rv-track { animation-play-state: paused; }
  @keyframes rvScroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  .rv-card { display: flex; flex-direction: column; gap: 10px; width: 272px; flex-shrink: 0; background: rgba(255, 255, 255, 0.85); border: 1.5px solid rgba(25, 123, 255, 0.14); border-radius: 16px; padding: 16px 18px; text-decoration: none; color: var(--ink, #1c2b3a); box-shadow: 0 6px 18px rgba(15, 53, 103, 0.06); backdrop-filter: blur(8px); transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease; }
  .rv-card:hover { transform: translateY(-3px); border-color: rgba(25, 123, 255, 0.4); box-shadow: 0 14px 34px rgba(15, 53, 103, 0.14); }
  .rv-head { display: flex; align-items: center; gap: 10px; }
  .rv-stars { color: #f5b942; letter-spacing: 1px; font-size: 0.7rem; }
  .rv-g { margin-left: auto; font-weight: 800; font-family: var(--font-display); font-size: 1.05rem; background: conic-gradient(from -45deg, #4285F4, #34A853, #FBBC05, #EA4335, #4285F4); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .rv-text { margin: 0; font-size: 0.87rem; line-height: 1.55; color: #2a3c52; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .rv-avatar { position: relative; width: 34px; height: 34px; border-radius: 50%; display: grid; place-items: center; color: #fff; font-weight: 800; font-size: 0.85rem; background: linear-gradient(135deg, var(--blue), var(--accent)); box-shadow: 0 4px 12px rgba(25, 123, 255, 0.35); flex-shrink: 0; }
  .rv-avatar img { position: absolute; inset: 0; width: 100%; height: 100%; border-radius: 50%; object-fit: cover; border: 2px solid rgba(255, 255, 255, 0.9); }
  .rv-meta { display: flex; flex-direction: column; line-height: 1.3; min-width: 0; }
  .rv-meta b { font-size: 0.88rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .rv-meta em { font-style: normal; font-size: 0.74rem; color: var(--muted, #5b6b7e); }
  .rv-note { text-align: center; font-size: 0.85rem; color: var(--muted, #5b6b7e); margin: 16px 0 0; }
  .rv-note a { color: var(--blue); font-weight: 700; }
  @media (max-width: 640px) { .rv-card { width: 240px; } }
  @media (prefers-reduced-motion: reduce) { .rv-track { animation: none; } .rv-row { overflow-x: auto; } }
  /* Mobile performance tier: no blur compositing on touch devices */
  @media (pointer: coarse), (max-width: 1023px) {
    .rv-card { backdrop-filter: none !important; -webkit-backdrop-filter: none !important; background: #fff !important; }
  }
</style>
