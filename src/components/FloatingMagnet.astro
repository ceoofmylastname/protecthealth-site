---
// Floating lead-magnet CTA — persistent PDF offer that follows the visitor down the page.
// Appears after a short scroll, stays visible everywhere, dismissible per browser session.
interface Props {
  href: string;
  cover: string;
  label: string;
  title: string;
  cta?: string;
}
const { href, cover, label, title, cta = 'Get the free PDF' } = Astro.props;
---
<div class="fmag" id="fmag" data-key={href} hidden>
  <a class="fmag-link" href={href}>
    <img class="fmag-cover" src={cover} alt="" width="52" height="67" loading="lazy" />
    <span class="fmag-txt">
      <b>{label}</b>
      <em>{title}</em>
    </span>
    <span class="fmag-cta">{cta} →</span>
  </a>
  <button class="fmag-x" type="button" aria-label="Dismiss free PDF offer">✕</button>
</div>

<style>
  .fmag {
    position: fixed;
    right: 18px;
    bottom: calc(16px + env(safe-area-inset-bottom, 0px));
    z-index: 150;
    display: flex;
    align-items: stretch;
    max-width: 500px;
    opacity: 0;
    transform: translateY(18px) scale(0.97);
    pointer-events: none;
    transition: opacity 0.45s ease, transform 0.45s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .fmag.on { opacity: 1; transform: none; pointer-events: auto; }
  .fmag[hidden] { display: none; }

  .fmag-link {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.96);
    border: 1.5px solid rgba(25, 123, 255, 0.22);
    border-radius: 18px;
    padding: 10px 14px 10px 10px;
    box-shadow: 0 18px 48px rgba(8, 29, 61, 0.28);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .fmag-link:hover { transform: translateY(-3px); border-color: rgba(25, 123, 255, 0.5); box-shadow: 0 24px 60px rgba(8, 29, 61, 0.34); }

  .fmag-cover { width: 52px; height: auto; border-radius: 7px; box-shadow: 0 8px 18px rgba(15, 53, 103, 0.3); transform: rotate(-3deg); flex-shrink: 0; }
  .fmag-txt { display: flex; flex-direction: column; line-height: 1.3; min-width: 0; }
  .fmag-txt b { font-size: 0.72rem; font-weight: 800; letter-spacing: 1.4px; text-transform: uppercase; background: linear-gradient(120deg, var(--blue, #197bff), var(--accent, #19c8ff)); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .fmag-txt em { font-style: normal; font-weight: 700; color: var(--navy, #0f3567); font-size: 0.9rem; margin-top: 2px; }
  .fmag-cta { flex-shrink: 0; align-self: center; white-space: nowrap; font-weight: 800; font-size: 0.84rem; color: #fff; background: linear-gradient(120deg, var(--blue, #197bff), var(--accent, #19c8ff)); padding: 10px 16px; border-radius: 999px; box-shadow: 0 8px 20px rgba(25, 123, 255, 0.35); }

  .fmag-x {
    position: absolute;
    top: -9px;
    left: -9px;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: 1px solid rgba(15, 53, 103, 0.15);
    background: #fff;
    color: #5b6b7e;
    font-size: 0.72rem;
    font-weight: 700;
    cursor: pointer;
    display: grid;
    place-items: center;
    box-shadow: 0 4px 12px rgba(8, 29, 61, 0.2);
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .fmag-x:hover { transform: scale(1.12); color: var(--navy, #0f3567); }

  @media (max-width: 700px) {
    .fmag { right: 10px; left: 10px; bottom: calc(10px + env(safe-area-inset-bottom, 0px)); max-width: none; }
    .fmag-link { flex: 1; gap: 10px; padding: 8px 10px; border-radius: 16px; backdrop-filter: none; -webkit-backdrop-filter: none; background: #fff; }
    .fmag-cover { width: 40px; }
    .fmag-txt b { font-size: 0.64rem; }
    .fmag-txt em { font-size: 0.8rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .fmag-cta { font-size: 0.78rem; padding: 9px 13px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .fmag { transition: opacity 0.3s ease; transform: none; }
  }
</style>

<script>
  const el = document.getElementById('fmag');
  if (el) {
    const key = `fmag-dismissed:${el.getAttribute('data-key')}`;
    let dismissed = false;
    try { dismissed = sessionStorage.getItem(key) === '1'; } catch {}
    if (!dismissed) {
      el.hidden = false;
      let shown = false;
      const check = () => {
        if (!shown && window.scrollY > 420) {
          shown = true;
          el.classList.add('on');
          window.removeEventListener('scroll', check);
        }
      };
      window.addEventListener('scroll', check, { passive: true });
      check();
      el.querySelector('.fmag-x')?.addEventListener('click', () => {
        el.classList.remove('on');
        try { sessionStorage.setItem(key, '1'); } catch {}
        setTimeout(() => { el.hidden = true; }, 500);
      });
    }
  }
</script>
