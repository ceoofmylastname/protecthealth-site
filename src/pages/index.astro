---
import Base from '../layouts/Base.astro';
import ReviewBadge from '../components/ReviewBadge.astro';
import { SITE, ASSETS, HF_ASSETS, TEAM, breadcrumbSchema, speakableSchema } from '../lib/site';
import { SERVICES } from '../lib/services';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.datePublished.localeCompare(a.data.datePublished))
  .slice(0, 3);

const schemas = [
  speakableSchema(SITE.domain),
  breadcrumbSchema([{ name: 'Home', url: `${SITE.domain}/` }]),
];
---
<Base
  title="Insurance Strategy For Everyone | ProtectHealth Las Vegas"
  description="ProtectHealth is a Las Vegas insurance brokerage that builds coverage around your life and business — health, life, dental, vision, Medicare, and employer benefits. Strategy first, product second."
  schemas={schemas}
>
  <!-- ============ HERO ============ -->
  <section class="lux-hero">
    <div class="mesh m1"></div><div class="mesh m2"></div><div class="mesh m3"></div>
    <div class="container lux-hero-grid">
      <div class="lux-hero-copy">
        <div class="kicker reveal">Protection. Trustworthy. Personalized.</div>
        <h1 class="reveal d1">Insurance strategy for everyone. <span class="grad-text">Not just insurance products.</span></h1>
        <p class="lead reveal d2">Most of the industry starts with a product. ProtectHealth starts with you — how your household or business is structured, what you actually need, and what you can access.</p>
        <div class="hero-ctas reveal d3">
          <a href="/contact-us" class="btn big glow">Talk To A Broker</a>
          <a href="/free-quote" class="btn big glass no-arrow">Get Started</a>
        </div>
        <div class="avatars-strip reveal d4">
          <div class="avatars">
            {ASSETS.avatars.map((a) => <img src={a} alt="ProtectHealth client" width="46" height="46" loading="lazy" />)}
          </div>
          <div class="txt"><b><span class="stars">★★★★★</span> <span data-count="4.9" data-dec="1">4.9</span> rating</b>Trusted by Nevadans across Clark County</div>
        </div>
      </div>
      <div class="lux-hero-photo reveal d2">
        <img src={HF_ASSETS.hero} alt="Las Vegas family protected by a ProtectHealth coverage strategy" loading="eager" />
        <a class="float-pill p1" href={SITE.reviews.url} target="_blank" rel="noopener noreferrer"><span class="stars">★★★★★</span> 703+ Google reviews</a>
        <div class="float-pill p2">✓ Official Paychex Partner</div>
        <div class="float-pill p3">$0 consultations. Always.</div>
      </div>
    </div>
  </section>

  <!-- ============ MARQUEE ============ -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      {[1,2].map(() => (
        <span>Strategy over product <i>✦</i> 4.9 stars · 703+ Google reviews <i>✦</i> Las Vegas · Nevada <i>✦</i> Official Paychex Partner <i>✦</i> Health · Life · Medicare · Dental · Vision <i>✦</i> Insurance nerds, not tax professionals <i>✦</i> </span>
      ))}
    </div>
  </div>

  <!-- ============ STATS ============ -->
  <section class="section" style="padding-bottom:30px;">
    <div class="container">
      <div class="stat-row">
        <div class="stat reveal"><div class="num"><span data-count="4.9" data-dec="1">0</span></div><div class="lbl">Google rating</div></div>
        <div class="stat reveal d1"><div class="num"><span data-count="703">0</span>+</div><div class="lbl">Five-star reviews</div></div>
        <div class="stat reveal d2"><div class="num"><span data-count="6">0</span></div><div class="lbl">Coverage lines</div></div>
        <div class="stat reveal d3"><div class="num">$<span data-count="0">0</span></div><div class="lbl">Cost to talk to us</div></div>
      </div>
      <div id="ai-summary" style="margin-top:38px;">
        ProtectHealth is a Las Vegas, Nevada insurance brokerage serving individuals, families, self-employed professionals, and small businesses. ProtectHealth brokers compare plans across carriers for health, life, GAP, Medicare, dental, and vision coverage, and help business owners explore employer benefits alongside payroll and HR support through an official Paychex partnership. Consultations are free and start with strategy, not a sales pitch.
      </div>
    </div>
  </section>

  <!-- ============ SERVICES ============ -->
  <section class="section soft rounded-section">
    <div class="container">
      <div class="section-head center">
        <div class="section-label">Our Portfolio</div>
        <h2 style="margin-top:0;">Coverage we build <span class="grad-text">strategies</span> around</h2>
        <p style="color:var(--muted);">Whether you're covering a family, a business, or just yourself — the process starts with you, not a plan brochure.</p>
      </div>
      <div class="grid cols-3">
        {SERVICES.map((s, i) => (
          <a class={`icon-card reveal d${i % 3}`} href={`/services/${s.slug}`}>
            <div class="icon-wrap"><img src={HF_ASSETS.icons[s.slug]} alt="" width="86" height="86" loading="lazy" /></div>
            <h3>{s.name}</h3>
            <p>{s.description}</p>
            <span class="more">Learn More →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ WHY / ADVISOR ============ -->
  <section class="section">
    <div class="container">
      <div class="split-feature">
        <div class="photo tilt reveal"><img src={HF_ASSETS.advisor} alt="ProtectHealth broker walking a couple through their coverage strategy" loading="lazy" /></div>
        <div class="reveal d1">
          <div class="section-label">Why have insurance?</div>
          <h2 style="margin-top:0;">You can't buy it <span class="grad-text">after</span> you need it.</h2>
          <p>You can't buy auto insurance after someone crashes into you, and you can't buy health insurance after you get sick or injured. Coverage only works when it's in place before the bad day.</p>
          <ul class="checklist">
            <li>Built around age, income &amp; tax-credit eligibility</li>
            <li>Networks checked against your actual doctors</li>
            <li>Prescriptions priced before you enroll</li>
            <li>Total financial exposure — not just the premium</li>
          </ul>
          <a href="/about-us" class="btn" style="margin-top:16px;">Our Approach</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CAMPAIGN DUO ============ -->
  <section class="section" style="padding-top:20px;">
    <div class="container">
      <div class="grid cols-2">
        <a class="photo-card reveal" href="/self-employed">
          <img src={HF_ASSETS.realtor} alt="Self-employed Las Vegas Realtor" loading="lazy" />
          <div class="pc-overlay"></div>
          <div class="pc-body">
            <span class="pc-tag">Realtors · 1099 · Self-Employed</span>
            <h3>Your coverage should be built around your business.</h3>
            <p>ICHRA, Section 105, genuine PPO access, small-group opportunities — the options nobody ever explained.</p>
            <span class="pc-btn">Explore The Strategy →</span>
          </div>
        </a>
        <a class="photo-card reveal d1" href="/employers">
          <img src={HF_ASSETS.employers} alt="Las Vegas small business team" loading="lazy" />
          <div class="pc-overlay"></div>
          <div class="pc-body">
            <span class="pc-tag">Business Owners · Paychex Partner</span>
            <h3>Your insurance agency just got a much bigger toolbox.</h3>
            <p>Benefits, payroll, HR, compliance, and retirement — one conversation, the whole employer picture.</p>
            <span class="pc-btn">See What That Unlocks →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ WHY CHOOSE / NAVY ============ -->
  <section class="section" style="padding-top:20px;">
    <div class="container">
      <div class="navy-band lux">
        <div class="band-glow"></div>
        <div class="section-label" style="color:#8ec9ff;">Why Choose Us?</div>
        <h2 style="margin-top:0;max-width:560px;">We understand that everyone's insurance needs are unique.</h2>
        <div class="grid cols-2">
          <div class="feature-num reveal"><div class="n">1</div><div><h3>Customized Coverage</h3><p>Strategies built around your household, your business structure, and your real financial exposure.</p></div></div>
          <div class="feature-num reveal d1"><div class="n">2</div><div><h3>Exceptional Customer Service</h3><p>A dedicated team ready to assist with any question — before, during, and after enrollment.</p></div></div>
          <div class="feature-num reveal d2"><div class="n">3</div><div><h3>Trusted Expertise</h3><p>Years of industry experience across health, life, Medicare, and employer benefits.</p></div></div>
          <div class="feature-num reveal d3"><div class="n">4</div><div><h3>Strong Partnerships</h3><p>Transparency, integrity, and an official Paychex partnership that gives business owners a bigger toolbox.</p></div></div>
        </div>
      </div>
    </div>
  </section>

  <ReviewBadge variant="band" />

  <!-- ============ TEAM ============ -->
  <section class="section soft rounded-section">
    <div class="container">
      <div class="section-head center">
        <div class="section-label">Our Team</div>
        <h2 style="margin-top:0;">Meet the professionals behind the strategy</h2>
      </div>
      <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));">
        {TEAM.map((m, i) => (
          <a class={`team-card reveal d${i}`} href={`/team-members/${m.slug}`}>
            <div class="photo"><img src={m.photo} alt={`${m.name}, ${m.role} at ProtectHealth`} loading="lazy" /></div>
            <h3>{m.name}</h3>
            <div class="role">{m.role} · ProtectHealth</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ BLOG ============ -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div class="section-label">Blog / News</div>
        <h2 style="margin-top:0;">Our latest news &amp; guides</h2>
      </div>
      <div class="grid cols-3">
        {posts.map((p, i) => (
          <a class={`img-card reveal d${i}`} href={`/blog-post/${p.id}`} style="text-decoration:none;">
            {ASSETS.blog[p.id] && <div class="thumb"><img src={ASSETS.blog[p.id]} alt={p.data.title} loading="lazy" /></div>}
            <div class="body-pad">
              <span class="badge">{p.data.category}</span>
              <h3>{p.data.title}</h3>
              <p>{p.data.description}</p>
              <span class="more">Read More →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ FINAL CTA ============ -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="cta-band lux reveal">
        <h2>20 minutes. No pitch. <span style="color:#8ec9ff;">Just clarity.</span></h2>
        <p>Bring your current coverage — or your lack of it — and walk away knowing which options fit, which don't, and what questions to ask next. If what you have is right, ProtectHealth will tell you that too.</p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;">
          <a href="/contact-us" class="btn big white">Book A Strategy Conversation</a>
          <a href={SITE.phoneHref} class="btn big glass no-arrow">Call {SITE.phone}</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ===== luxury hero ===== */
  .lux-hero { position: relative; overflow: hidden; background: linear-gradient(125deg, #0a2246 0%, var(--navy) 45%, #17457e 100%); color: #fff; padding: 88px 0 96px; }
  .mesh { position: absolute; border-radius: 50%; filter: blur(90px); opacity: 0.5; animation: drift 16s ease-in-out infinite alternate; }
  .m1 { width: 560px; height: 560px; background: #197bff; top: -180px; right: -120px; }
  .m2 { width: 420px; height: 420px; background: #007db3; bottom: -160px; left: -140px; animation-delay: -5s; }
  .m3 { width: 300px; height: 300px; background: #19c8ff; top: 40%; left: 46%; opacity: 0.25; animation-delay: -9s; }
  @keyframes drift { from { transform: translate(0,0) scale(1); } to { transform: translate(46px,-34px) scale(1.12); } }
  .lux-hero-grid { position: relative; z-index: 2; display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 54px; align-items: center; }
  .lux-hero .kicker { text-transform: uppercase; letter-spacing: 3px; font-size: 0.78rem; font-weight: 800; color: #8ec9ff; margin-bottom: 16px; }
  .lux-hero h1 { color: #fff; }
  .grad-text { background: linear-gradient(92deg, #8ec9ff, #19c8ff 55%, #66e0ff); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .lux-hero .lead { color: #d9e6f7; font-size: 1.16rem; margin: 20px 0 30px; max-width: 560px; }
  .btn.glow { box-shadow: 0 0 0 0 rgba(25,200,255,0.55); animation: pulseGlow 2.6s ease-in-out infinite; }
  @keyframes pulseGlow { 0%,100% { box-shadow: 0 8px 26px rgba(0,125,179,0.45); } 50% { box-shadow: 0 8px 40px rgba(25,200,255,0.65); } }
  .btn.glass { background: rgba(255,255,255,0.1); border: 1.5px solid rgba(255,255,255,0.4); color: #fff; backdrop-filter: blur(8px); }
  .btn.glass:hover { background: rgba(255,255,255,0.2); }
  .lux-hero-photo { position: relative; }
  .lux-hero-photo img { width: 100%; aspect-ratio: 16/10; object-fit: cover; border-radius: 28px; box-shadow: 0 30px 80px rgba(0,0,0,0.45); border: 1px solid rgba(255,255,255,0.18); background: rgba(255,255,255,0.06); }
  .float-pill { position: absolute; background: rgba(255,255,255,0.94); color: var(--navy); font-weight: 800; font-size: 0.85rem; padding: 11px 18px; border-radius: 40px; box-shadow: 0 14px 34px rgba(10,34,70,0.35); backdrop-filter: blur(6px); text-decoration: none; animation: floaty 5.5s ease-in-out infinite; }
  .p1 { top: -18px; right: 8%; }
  .p2 { bottom: 18%; left: -26px; animation-delay: -1.8s; }
  .p3 { bottom: -16px; right: 14%; animation-delay: -3.4s; }
  @keyframes floaty { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-9px); } }

  /* ===== marquee ===== */
  .marquee { background: #0a2246; color: #8ec9ff; overflow: hidden; padding: 13px 0; border-top: 1px solid rgba(255,255,255,0.08); }
  .marquee-track { display: flex; white-space: nowrap; animation: marquee 30s linear infinite; font-size: 0.82rem; letter-spacing: 0.22em; text-transform: uppercase; font-weight: 700; }
  .marquee-track span { padding-right: 2ch; }
  .marquee-track i { color: #19c8ff; font-style: normal; padding: 0 1ch; }
  @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* ===== stats ===== */
  .stat-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; }
  .stat { background: linear-gradient(#fff,#fff) padding-box, linear-gradient(120deg, #197bff33, #007db355) border-box; border: 1.5px solid transparent; border-radius: 22px; padding: 26px; text-align: center; box-shadow: var(--shadow-sm); }
  .stat .num { font-size: 2.5rem; font-weight: 800; color: var(--navy); font-variant-numeric: tabular-nums; }
  .stat .lbl { color: var(--muted); font-size: 0.9rem; font-weight: 600; }

  /* ===== icon cards ===== */
  .rounded-section { border-radius: 44px 44px 0 0; }
  .icon-card { display: block; background: linear-gradient(#fff,#fff) padding-box, linear-gradient(135deg, #197bff2e, #007db34d) border-box; border: 1.5px solid transparent; border-radius: 26px; padding: 30px; text-decoration: none; box-shadow: var(--shadow-sm); transition: 0.22s; }
  .icon-card:hover { transform: translateY(-6px); box-shadow: 0 18px 44px rgba(15,53,103,0.16); }
  .icon-card .icon-wrap { width: 86px; height: 86px; border-radius: 24px; overflow: hidden; box-shadow: 0 8px 22px rgba(15,53,103,0.14); margin-bottom: 6px; }
  .icon-card h3 { margin: 14px 0 6px; }
  .icon-card p { color: var(--muted); font-size: 0.95rem; }
  .icon-card .more { color: var(--accent); font-weight: 700; }

  /* ===== checklist ===== */
  .checklist { list-style: none; margin: 16px 0 0 !important; }
  .checklist li { padding-left: 34px; position: relative; margin: 10px 0; font-weight: 600; color: var(--ink); }
  .checklist li::before { content: "✓"; position: absolute; left: 0; top: 0; width: 24px; height: 24px; border-radius: 50%; background: linear-gradient(135deg, var(--blue), var(--accent)); color: #fff; font-size: 0.8rem; font-weight: 800; display: flex; align-items: center; justify-content: center; }
  .tilt { transform: rotate(-1.6deg); }
  .tilt:hover { transform: rotate(0deg); transition: 0.35s; }

  /* ===== photo cards ===== */
  .photo-card { position: relative; display: block; border-radius: 28px; overflow: hidden; min-height: 430px; text-decoration: none; box-shadow: var(--shadow); }
  .photo-card img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .photo-card:hover img { transform: scale(1.05); }
  .pc-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(10,34,70,0.05) 20%, rgba(10,34,70,0.88) 78%); }
  .pc-body { position: absolute; left: 0; right: 0; bottom: 0; padding: 30px; color: #fff; }
  .pc-tag { display: inline-block; background: rgba(255,255,255,0.16); border: 1px solid rgba(255,255,255,0.35); backdrop-filter: blur(6px); font-size: 0.7rem; font-weight: 800; letter-spacing: 1.6px; text-transform: uppercase; padding: 6px 14px; border-radius: 30px; margin-bottom: 12px; }
  .pc-body h3 { color: #fff; margin: 0 0 8px; font-size: 1.35rem; }
  .pc-body p { color: #d9e6f7; font-size: 0.95rem; margin: 0 0 14px; }
  .pc-btn { font-weight: 800; color: #66e0ff; }

  /* ===== navy band lux ===== */
  .navy-band.lux { position: relative; overflow: hidden; border-radius: 30px; }
  .band-glow { position: absolute; width: 420px; height: 420px; border-radius: 50%; background: radial-gradient(circle, rgba(25,200,255,0.28), transparent 65%); top: -160px; right: -120px; animation: drift 14s ease-in-out infinite alternate; }
  .cta-band.lux { border-radius: 30px; }

  /* ===== reveal animations ===== */
  .reveal { opacity: 0; transform: translateY(26px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .reveal.in { opacity: 1; transform: none; }
  .d1 { transition-delay: 0.12s; } .d2 { transition-delay: 0.24s; } .d3 { transition-delay: 0.36s; } .d4 { transition-delay: 0.48s; }

  @media (max-width: 900px) {
    .lux-hero-grid { grid-template-columns: 1fr; gap: 38px; }
    .lux-hero { padding: 56px 0 64px; }
    .float-pill { font-size: 0.75rem; }
    .p2 { left: 6px; }
    .photo-card { min-height: 360px; }
    .rounded-section { border-radius: 28px 28px 0 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .mesh, .btn.glow, .float-pill, .marquee-track, .band-glow { animation: none !important; }
    .reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  // Scroll reveals + animated counters (respects reduced motion)
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const els = document.querySelectorAll('.reveal');
  if (reduce) { els.forEach((e) => e.classList.add('in')); }
  else {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((en) => { if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); } });
    }, { threshold: 0.15 });
    els.forEach((e) => io.observe(e));
  }
  const counters = document.querySelectorAll('[data-count]');
  const runCount = (el) => {
    const target = parseFloat(el.dataset.count || '0');
    const dec = parseInt(el.dataset.dec || '0');
    if (reduce || target === 0) { el.textContent = target.toFixed(dec); return; }
    const t0 = performance.now(); const dur = 1400;
    const step = (t) => {
      const p = Math.min(1, (t - t0) / dur);
      el.textContent = (target * (1 - Math.pow(1 - p, 3))).toFixed(dec);
      if (p < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  };
  const cio = new IntersectionObserver((entries) => {
    entries.forEach((en) => { if (en.isIntersecting) { runCount(en.target); cio.unobserve(en.target); } });
  }, { threshold: 0.4 });
  counters.forEach((c) => cio.observe(c));
</script>
