---
import Base from '../layouts/Base.astro';
import ReviewBadge from '../components/ReviewBadge.astro';
import { SITE, ASSETS, HF_ASSETS, TEAM, BLOG_ART, breadcrumbSchema, speakableSchema } from '../lib/site';
import { SERVICES } from '../lib/services';
import { GOOGLE_REVIEWS } from '../lib/reviews';
import { getCollection } from 'astro:content';

const reviewRowA = GOOGLE_REVIEWS.slice(0, 10);
const reviewRowB = GOOGLE_REVIEWS.slice(10);

// Cinematic intro: plays once per browser session on the homepage, then dissolves into the page.
const INTRO_VIDEO = 'https://d8j0ntlcm91z4.cloudfront.net/user_3GY61bj0wPgc3RYJDtgyJ6LmhTH/hf_20260722_062759_b0f2c41b-4f29-4be1-bdf5-f542bfd663af.mp4';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.datePublished.localeCompare(a.data.datePublished))
  .slice(0, 3);

const schemas = [
  speakableSchema(SITE.domain),
  breadcrumbSchema([{ name: 'Home', url: `${SITE.domain}/` }]),
];

// Inline SVG icon set — always renders, no network needed.
const ICONS: Record<string, string> = {
  'health-insurance': '<svg viewBox="0 0 48 48" fill="none"><path d="M24 41S7 30.6 7 18.5C7 12.7 11.6 8 17.4 8c3 0 5.7 1.3 6.6 3.3C24.9 9.3 27.6 8 30.6 8 36.4 8 41 12.7 41 18.5 41 30.6 24 41 24 41Z" stroke="url(#g)" stroke-width="2.6" stroke-linejoin="round"/><path d="M24 17v12M18 23h12" stroke="#19c8ff" stroke-width="2.6" stroke-linecap="round"/></svg>',
  'life-insurance': '<svg viewBox="0 0 48 48" fill="none"><path d="M6 24C6 14 14 7 24 7s18 7 18 17" stroke="url(#g)" stroke-width="2.6" stroke-linecap="round"/><path d="M6 24c3-3 6-3 9 0 3-3 6-3 9 0 3-3 6-3 9 0 3-3 6-3 9 0" stroke="url(#g)" stroke-width="2.6" stroke-linecap="round"/><path d="M24 24v12a5 5 0 0 0 10 0" stroke="#19c8ff" stroke-width="2.6" stroke-linecap="round"/></svg>',
  'gap-health-insurance': '<svg viewBox="0 0 48 48" fill="none"><rect x="5" y="16" width="14" height="16" rx="3.5" stroke="url(#g)" stroke-width="2.6"/><rect x="29" y="16" width="14" height="16" rx="3.5" stroke="url(#g)" stroke-width="2.6"/><path d="M19 24h10" stroke="#19c8ff" stroke-width="2.6" stroke-linecap="round" stroke-dasharray="3 4"/></svg>',
  'medicare': '<svg viewBox="0 0 48 48" fill="none"><path d="M24 5 40 11v11c0 10-6.7 17.4-16 21C14.7 39.4 8 32 8 22V11L24 5Z" stroke="url(#g)" stroke-width="2.6" stroke-linejoin="round"/><path d="M24 16v12M18 22h12" stroke="#19c8ff" stroke-width="2.6" stroke-linecap="round"/></svg>',
  'dental-insurance': '<svg viewBox="0 0 48 48" fill="none"><path d="M15 7c3 0 5.5 2 9 2s6-2 9-2c5 0 8 4 8 9 0 9-4 14-6 24-.5 2.4-3.6 2.6-4.4.3L27.5 30c-1-3-6-3-7 0l-3.1 10.3c-.8 2.3-3.9 2.1-4.4-.3C11 30 7 25 7 16c0-5 3-9 8-9Z" stroke="url(#g)" stroke-width="2.6" stroke-linejoin="round"/><path d="m33 13 1.2 2.6L37 17l-2.8 1.4L33 21l-1.2-2.6L29 17l2.8-1.4L33 13Z" fill="#19c8ff"/></svg>',
  'vision-insurance': '<svg viewBox="0 0 48 48" fill="none"><path d="M4 24S12 12 24 12s20 12 20 12-8 12-20 12S4 24 4 24Z" stroke="url(#g)" stroke-width="2.6" stroke-linejoin="round"/><circle cx="24" cy="24" r="6" stroke="#19c8ff" stroke-width="2.6"/></svg>',
};

// Real Google reviewer faces for the hero social-proof strip (photos from the live listing).
const HERO_REVIEWERS = ['Yvette Auger', 'Stephen Kuo', 'Rachel Wren', 'Yudith Felix']
  .map((n) => GOOGLE_REVIEWS.find((r) => r.name === n))
  .filter((r) => r && r.photo);
---
<Base
  title="Insurance Strategy For Everyone | ProtectHealth Las Vegas"
  description="ProtectHealth is a Las Vegas insurance brokerage that builds coverage around your life and business — health, life, dental, vision, Medicare, and employer benefits. Strategy first, product second."
  schemas={schemas}
>
  <!-- ============ CINEMATIC INTRO (plays once per session, dissolves into homepage) ============ -->
  <div id="site-intro" aria-hidden="true">
    <video id="intro-video" src={INTRO_VIDEO} muted playsinline preload="auto"></video>
    <div class="intro-brand">P R O T E C T H E A L T H</div>
    <button id="intro-skip" type="button">Skip Intro →</button>
  </div>

  <!-- shared SVG gradient defs -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true"><defs><linearGradient id="g" x1="0" y1="0" x2="48" y2="48"><stop stop-color="#197bff"/><stop offset="1" stop-color="#007db3"/></linearGradient></defs></svg>

  <!-- ============ HERO ============ -->
  <div id="scrollbar" aria-hidden="true"><i id="scrollbar-fill"></i></div>
  <section class="lux-hero" style="background-image:url('/assets/art-hero.webp')">
    <div class="hero-bg" id="heroBg" style={`background-image:url('${HF_ASSETS.hero}')`}></div>
    <div class="hero-duotone"></div>
    <div class="aurora"></div>
    <div class="mesh m1"></div><div class="mesh m2"></div><div class="mesh m3"></div>
    <div class="grain"></div>
    <div class="container lux-hero-grid">
      <div class="lux-hero-copy">
        <div class="kicker-chip reveal"><i class="kdot"></i> Strategy-First Insurance · Las Vegas</div>
        <h1 class="headline">
          <span class="hw">Strategy</span> <span class="hw hl-under">first.<svg viewBox="0 0 180 14" preserveAspectRatio="none" aria-hidden="true"><path d="M4 10 C 50 3, 130 3, 176 8" fill="none" stroke="url(#hu)" stroke-width="6" stroke-linecap="round"/><defs><linearGradient id="hu" x1="0" y1="0" x2="180" y2="0" gradientUnits="userSpaceOnUse"><stop stop-color="#19c8ff"/><stop offset="1" stop-color="#66e0ff"/></linearGradient></defs></svg></span><br/>
          <span class="hw grad-anim">Insurance</span> <span class="hw grad-anim">second.</span>
        </h1>
        <p class="lead reveal d3">The rest of the industry starts with a product. <b style="color:#fff;">ProtectHealth starts with how your life and business are actually built.</b></p>
        <div class="hero-ctas reveal d4">
          <a href="/contact-us" class="btn big glow">Talk To A Broker</a>
          <a href="/free-quote" class="btn big glass no-arrow">Get Started</a>
        </div>
        <div class="avatars-strip reveal d5">
          <div class="avatars-init">
            {HERO_REVIEWERS.map((r) => (
              <span title={`${r.name} · Google review`}>
                {r.name.split(' ').map((w) => w[0]).join('').slice(0, 2)}
                <img src={r.photo} alt={`${r.name}, Google reviewer`} loading="lazy" referrerpolicy="no-referrer" onerror="this.remove()" />
              </span>
            ))}
          </div>
          <div class="txt"><b><span class="stars">★★★★★</span> <span data-count="4.9" data-dec="1">4.9</span> rating</b>Trusted by Nevadans across Clark County</div>
        </div>
      </div>

      <!-- glass strategy card (self-contained, photo enhances behind) -->
      <div class="hero-panel reveal d3">
        <div class="hero-photo" style={`background-image:url('${HF_ASSETS.hero}')`}></div>
        <div class="glass-card spot tilt">
          <div class="gc-row"><span class="stars">★★★★★</span><b>4.9</b><span class="gc-muted">· 703+ Google reviews</span></div>
          <div class="gc-title">Your coverage strategy</div>
          <ul class="gc-list">
            <li><i>✓</i> Network checked against your doctors</li>
            <li><i>✓</i> Tax-credit eligibility mapped</li>
            <li><i>✓</i> Business structure reviewed</li>
            <li><i>✓</i> Total exposure, not just premium</li>
          </ul>
          <div class="gc-foot">Strategy conversation · 20 min · $0</div>
        </div>
        <div class="float-pill p2">✓ Official Paychex Partner</div>
      </div>
    </div>
  </section>

  <!-- ============ MARQUEE ============ -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      {[1,2].map(() => (
        <span>Strategy over product <i>✦</i> 4.9 stars · 703+ Google reviews <i>✦</i> Las Vegas · Nevada <i>✦</i> Official Paychex Partner <i>✦</i> Health · Life · Medicare · Dental · Vision <i>✦</i> Insurance nerds, not tax professionals <i>✦</i> </span>
      ))}
    </div>
  </div>

  <!-- ============ STATS ============ -->
  <section class="section grad-soft" style="padding-bottom:34px;">
    <div class="container">
      <div class="stat-row">
        <div class="stat spot tilt glassy reveal"><div class="num"><span data-count="4.9" data-dec="1">0</span></div><div class="lbl">Google rating</div><i class="tick"></i></div>
        <div class="stat spot tilt glassy reveal d1"><div class="num"><span data-count="703">0</span>+</div><div class="lbl">Five-star reviews</div><i class="tick"></i></div>
        <div class="stat spot tilt glassy reveal d2"><div class="num"><span data-count="6">0</span></div><div class="lbl">Coverage lines</div><i class="tick"></i></div>
        <div class="stat spot tilt glassy reveal d3"><div class="num">$<span data-count="0">0</span></div><div class="lbl">Cost to talk to us</div><i class="tick"></i></div>
      </div>
      <div class="ai-wrap spot reveal">
        <div class="ai-label">The ProtectHealth Difference</div>
        <div id="ai-summary">
          ProtectHealth is a Las Vegas, Nevada insurance brokerage serving individuals, families, self-employed professionals, and small businesses. ProtectHealth brokers compare plans across carriers for health, life, GAP, Medicare, dental, and vision coverage, and help business owners explore employer benefits alongside payroll and HR support through an official Paychex partnership. Consultations are free and start with strategy, not a sales pitch.
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SERVICES ============ -->
  <!-- ============ COVERAGE — sticky stacking deck ============ -->
  <section class="stackzone" id="coverage">
    <div class="sz-gridbg" aria-hidden="true"></div>
    <div class="sz-glow" aria-hidden="true"></div>
    <div class="container sz-cols">
      <div class="sz-left">
        <div class="sz-pinhead">
          <div class="section-label" style="background:linear-gradient(90deg,#66e0ff,#8ec9ff);-webkit-background-clip:text;background-clip:text;">Our Portfolio</div>
          <h2>Six lines of coverage.<br /><span class="hs-grad">One strategy.</span></h2>
          <p>Whether you're covering a family, a business, or just yourself, the process starts with you, not a plan brochure. Keep scrolling and watch the deck stack up.</p>
          <a href="/buyers-guide" class="btn big glass no-arrow" style="margin-top:8px;">Read The Buyer's Guide</a>
        </div>
      </div>
      <div class="sz-right">
        {SERVICES.map((s, i) => (
          <figure class="sz-pin">
            <a class={`sz-card r${i % 3}`} href={`/services/${s.slug}`} style={`--i:${i}`}>
              <div class="sz-top">
                <div class="icon-squircle" set:html={ICONS[s.slug]} />
                <span class="sz-idx">0{i + 1}</span>
              </div>
              <h3>{s.name}</h3>
              <p>{s.description}</p>
              <span class="sz-more">Learn More →</span>
            </a>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ WHY / ADVISOR ============ -->
  <section class="section">
    <div class="container">
      <div class="split-feature">
        <div class="why-panel reveal" style="background-image:url('/assets/art-light.webp')">
          <div class="why-photo" style={`background-image:url('${HF_ASSETS.advisor}')`}></div>
          <div class="chip c1"><b>Networks</b> checked first</div>
          <div class="chip c2"><b>Tax credits</b> mapped</div>
          <div class="chip c3"><b>$0</b> consultation</div>
        </div>
        <div class="reveal d1">
          <div class="section-label">Why have insurance?</div>
          <h2 style="margin-top:0;">You can't buy it <span class="grad-text">after</span> you need it.</h2>
          <p>You can't buy auto insurance after someone crashes into you, and you can't buy health insurance after you get sick or injured. Coverage only works when it's in place before the bad day.</p>
          <ul class="checklist">
            <li>Built around age, income &amp; tax-credit eligibility</li>
            <li>Networks checked against your actual doctors</li>
            <li>Prescriptions priced before you enroll</li>
            <li>Total financial exposure — not just the premium</li>
          </ul>
          <a href="/about-us" class="btn" style="margin-top:16px;">Our Approach</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CAMPAIGN DUO ============ -->
  <section class="section" style="padding-top:20px;">
    <div class="container">
      <div class="grid cols-2">
        <a class="photo-card spot tilt reveal" href="/self-employed" style="background-image:url('/assets/art-realtor.webp')">
          <div class="pc-photo" style={`background-image:url('${HF_ASSETS.realtor}')`}></div>
          <div class="pc-overlay"></div>
          <div class="pc-body">
            <span class="pc-tag">Realtors · 1099 · Self-Employed</span>
            <h3>Your coverage should be built around your business.</h3>
            <p>ICHRA, Section 105, genuine PPO access, small-group opportunities — the options nobody ever explained.</p>
            <span class="pc-btn">Explore The Strategy →</span>
          </div>
        </a>
        <a class="photo-card spot tilt reveal d1" href="/employers" style="background-image:url('/assets/art-employers.webp')">
          <div class="pc-photo" style={`background-image:url('${HF_ASSETS.employers}')`}></div>
          <div class="pc-overlay"></div>
          <div class="pc-body">
            <span class="pc-tag">Business Owners · Paychex Partner</span>
            <h3>Your insurance agency just got a much bigger toolbox.</h3>
            <p>Benefits, payroll, HR, compliance, and retirement — one conversation, the whole employer picture.</p>
            <span class="pc-btn">See What That Unlocks →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ WHY CHOOSE / NAVY ============ -->
  <section class="section" style="padding-top:20px;">
    <div class="container">
      <div class="navy-band lux" style="background-image:url('/assets/art-cta.webp');background-size:cover;">
        <div class="band-glow"></div>
        <div class="section-label" style="color:#8ec9ff;">Why Choose Us?</div>
        <h2 style="margin-top:0;max-width:560px;">We understand that everyone's insurance needs are unique.</h2>
        <div class="grid cols-2">
          <div class="feature-num reveal"><div class="n">1</div><div><h3>Customized Coverage</h3><p>Strategies built around your household, your business structure, and your real financial exposure.</p></div></div>
          <div class="feature-num reveal d1"><div class="n">2</div><div><h3>Exceptional Customer Service</h3><p>A dedicated team ready to assist with any question — before, during, and after enrollment.</p></div></div>
          <div class="feature-num reveal d2"><div class="n">3</div><div><h3>Trusted Expertise</h3><p>Years of industry experience across health, life, Medicare, and employer benefits.</p></div></div>
          <div class="feature-num reveal d3"><div class="n">4</div><div><h3>Strong Partnerships</h3><p>Transparency, integrity, and an official Paychex partnership that gives business owners a bigger toolbox.</p></div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ REVIEW SHOWCASE ============ -->
  <!-- ============ v8: HORIZONTAL SCROLL JOURNEY ============ -->
  <section class="hscroll" id="method" aria-label="The ProtectHealth method">
    <div class="hs-sticky">
      <div class="container hs-head">
        <div class="section-label" style="color:#8ec9ff;">The ProtectHealth Method</div>
        <h2>Keep scrolling. <span class="hs-grad">The room turns.</span></h2>
      </div>
      <div class="hs-track" id="hsTrack">
        <article class="hs-panel">
          <div class="hs-num">01</div>
          <h3>Listen</h3>
          <p>The first 20 minutes are about your life, not our products. Household, work, doctors, prescriptions, what keeps you up at night. No brochure makes an appearance.</p>
          <a href="/contact-us" class="hs-link">Start the conversation →</a>
        </article>
        <article class="hs-panel">
          <div class="hs-num">02</div>
          <h3>Map</h3>
          <p>Income, tax-credit eligibility, business structure, real financial exposure. The full picture becomes a map, and the map decides what even belongs on the table.</p>
          <a href="/buyers-guide" class="hs-link">See how we think →</a>
        </article>
        <article class="hs-panel">
          <div class="hs-num">03</div>
          <h3>Match</h3>
          <p>Only now do products enter the room, auditioning for a job that's already defined. The product serves the strategy, never the other way around.</p>
          <a href="/services" class="hs-link">The coverage lines →</a>
        </article>
        <article class="hs-panel">
          <div class="hs-num">04</div>
          <h3>Stay</h3>
          <p>Enrollment is the start, not the finish. Renewals, network shuffles, formulary drift, life changes. The strategy gets maintained by people who answer the phone.</p>
          <a href="/our-team" class="hs-link">Meet the team →</a>
        </article>
      </div>
      <div class="hs-progress" aria-hidden="true"><i id="hsFill"></i></div>
    </div>
  </section>

  <section class="section" style="padding-top:26px;">
    <div class="container">
      <a class="review-showcase spot reveal" href={SITE.reviews.url} target="_blank" rel="noopener noreferrer">
        <div class="rs-glow"></div>
        <div class="rs-left">
          <div class="rs-g">G</div>
          <div>
            <div class="rs-stars stars">★★★★★</div>
            <div class="rs-big"><span data-count="4.9" data-dec="1">4.9</span> <em>/ 5</em></div>
          </div>
        </div>
        <div class="rs-mid">
          <div class="rs-count"><span data-count="703">703</span>+ Google reviews</div>
          <div class="rs-sub">Insurance agency in Clark County, Nevada — rated by the people who had the conversation.</div>
        </div>
        <div class="rs-cta">Read the reviews →</div>
      </a>
    </div>

    <!-- Real Google reviews wall — verbatim from the live listing, display-only (no review schema by design) -->
    <div class="review-wall reveal">
      {[reviewRowA, reviewRowB].map((row, ri) => (
        <div class={`rv-row ${ri === 1 ? 'rv-reverse' : ''}`}>
          <div class="rv-track">
            {[...row, ...row].map((r) => (
              <a class="rv-card" href={SITE.reviews.url} target="_blank" rel="noopener noreferrer" aria-label={`Google review by ${r.name}`}>
                <div class="rv-head">
                  <span class="rv-avatar">
                    {r.name.charAt(0)}
                    {r.photo && <img src={r.photo} alt={`${r.name} on Google`} loading="lazy" referrerpolicy="no-referrer" onerror="this.remove()" />}
                  </span>
                  <span class="rv-meta"><b>{r.name}</b><em><span class="rv-stars">★★★★★</span> · {r.date}</em></span>
                  <span class="rv-g">G</span>
                </div>
                <p class="rv-text">{r.text}</p>
              </a>
            ))}
          </div>
        </div>
      ))}
      <p class="rv-note">Real reviews, word for word, from ProtectHealth's Google listing. <a href={SITE.reviews.url} target="_blank" rel="noopener noreferrer">Read all {SITE.reviews.count}+ on Google</a>.</p>
    </div>
  </section>

  <!-- ============ TEAM ============ -->
  <section class="section soft rounded-section">
    <div class="container">
      <div class="section-head center">
        <div class="section-label">Our Team</div>
        <h2 style="margin-top:0;">Meet the professionals behind the strategy</h2>
        <p style="color:var(--muted);max-width:560px;margin:10px auto 0;">Six licensed brokers, one philosophy: the product should serve the strategy, not become the strategy.</p>
      </div>
      <div class="team-fan reveal">
        {TEAM.map((m, i) => {
          const d = i - (TEAM.length - 1) / 2;
          return (
            <a
              class="fan-card"
              href={`/team-members/${m.slug}`}
              aria-label={`${m.name}, ${m.role} at ProtectHealth`}
              style={`--fx:${(d * 95).toFixed(0)}px; --fy:${(Math.abs(d) * -26).toFixed(0)}px; --fr:${(d * 10).toFixed(1)}deg; --fd:${i * 90}ms; z-index:${TEAM.length - Math.round(Math.abs(d) * 2)};`}
            >
              <img src={m.photo} alt={`${m.name}, ${m.role} at ProtectHealth`} loading="lazy" />
              <span class="fan-name"><b>{m.name.split(' ')[0]}</b>{m.role.split('/')[0].trim()}</span>
            </a>
          );
        })}
      </div>
      <div style="text-align:center;margin-top:26px;">
        <a href="/our-team" class="btn">Meet The Whole Team</a>
      </div>
    </div>
  </section>

  <!-- ============ BLOG ============ -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div class="section-label">Blog / News</div>
        <h2 style="margin-top:0;">Our latest news &amp; guides</h2>
      </div>
      <div class="grid cols-3">
        {posts.map((p, i) => (
          <a class={`img-card spot tilt reveal d${i}`} href={`/blog-post/${p.id}`} style="text-decoration:none;">
            <div class="thumb grad-thumb">{BLOG_ART[p.id] && <img src={BLOG_ART[p.id].webp} alt={BLOG_ART[p.id].alt} loading="lazy" />}</div>
            <div class="body-pad">
              <span class="badge">{p.data.category}</span>
              <h3>{p.data.title}</h3>
              <p>{p.data.description}</p>
              <span class="more">Read More →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ FINAL CTA ============ -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="cta-band lux reveal" style="background-image:url('/assets/art-cta.webp');background-size:cover;">
        <h2>20 minutes. No pitch. <span style="color:#66e0ff;">Just clarity.</span></h2>
        <p>Bring your current coverage — or your lack of it — and walk away knowing which options fit, which don't, and what questions to ask next. If what you have is right, ProtectHealth will tell you that too.</p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;">
          <a href="/contact-us" class="btn big white">Book A Strategy Conversation</a>
          <a href={SITE.phoneHref} class="btn big glass no-arrow">Call {SITE.phone}</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ===== hero ===== */
  .lux-hero { position: relative; overflow: hidden; background-color: #0a2246; background-size: cover; background-position: center; color: #fff; padding: 92px 0 100px; border-radius: 34px; margin: 8px 14px 0; }
  .mesh { position: absolute; border-radius: 50%; filter: blur(90px); opacity: 0.45; animation: drift 16s ease-in-out infinite alternate; }
  .m1 { width: 560px; height: 560px; background: #197bff; top: -180px; right: -120px; }
  .m2 { width: 420px; height: 420px; background: #007db3; bottom: -160px; left: -140px; animation-delay: -5s; }
  .m3 { width: 300px; height: 300px; background: #19c8ff; top: 40%; left: 46%; opacity: 0.22; animation-delay: -9s; }
  @keyframes drift { from { transform: translate(0,0) scale(1); } to { transform: translate(46px,-34px) scale(1.12); } }
  .grain { position: absolute; inset: 0; opacity: 0.05; background-image: radial-gradient(rgba(255,255,255,0.7) 0.6px, transparent 0.6px); background-size: 3px 3px; pointer-events: none; }
