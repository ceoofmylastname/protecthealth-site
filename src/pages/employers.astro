---
// BOFU terminus for the Paychex cluster. Copy from the approved Paychex Launch Kit.
// v7 journey treatment: hero → pain → partnership → who it's for → proof → process → team → FAQ → conversation.
import Base from '../layouts/Base.astro';
import LeadForm from '../components/LeadForm.astro';
import FAQSection from '../components/FAQSection.astro';
import { SITE, ORG_ID, TEAM, HF_ASSETS, BLOG_ART, breadcrumbSchema, speakableSchema } from '../lib/site';
import ReviewWall from '../components/ReviewWall.astro';
import { getCollection } from 'astro:content';

const pageUrl = `${SITE.domain}/employers`;

// Reading library: every employers-cluster post + Q&A, TOFU first (auto-updates as content grows)
const clusterPosts = (await getCollection('blog'))
  .filter((p) => p.data.cluster === 'employers')
  .sort((a, b) => (a.data.funnelStage === b.data.funnelStage ? 0 : a.data.funnelStage === 'TOFU' ? -1 : 1));
const clusterQa = (await getCollection('qa'))
  .filter((q) => q.data.cluster === 'employers')
  .sort((a, b) => a.data.question.localeCompare(b.data.question));
const faq = [
  { q: 'What does the ProtectHealth and Paychex partnership include?', a: 'ProtectHealth has officially partnered with Paychex to help small businesses explore payroll, HR support, compliance, benefits administration, onboarding, retirement plans, and other employer-support solutions alongside their insurance strategy.' },
  { q: 'Is ProtectHealth becoming a payroll company?', a: 'No. ProtectHealth handles the benefits strategy conversation. When payroll, HR infrastructure, or employer services are worth exploring, ProtectHealth connects the business owner directly with a dedicated Paychex team.' },
  { q: 'What kinds of businesses fit this best?', a: 'Businesses with employees: restaurants and hospitality with tipped teams, offices with no formal HR structure, companies adding people or locations, and any owner whose back office is getting heavier than it should be.' },
  { q: 'Does exploring the Paychex partnership cost anything?', a: 'No. The conversation with ProtectHealth is free, and there is no obligation to change payroll providers or buy anything to have it.' },
  { q: 'Can ProtectHealth help with tax credits for tipped businesses?', a: 'Tipped payroll can carry tax-credit opportunities worth exploring with the Paychex team. ProtectHealth brokers are insurance professionals, not tax professionals — a business\'s CPA should always be in the loop on tax-credit decisions.' },
];

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Employer Benefits Strategy + Paychex Partnership — ProtectHealth',
    description: 'ProtectHealth has officially partnered with Paychex to help small businesses explore payroll, HR, compliance, benefits administration, and employer-support solutions alongside their insurance strategy.',
    provider: { '@id': ORG_ID },
    areaServed: { '@type': 'State', name: 'Nevada' },
    url: pageUrl,
  },
  speakableSchema(pageUrl),
  breadcrumbSchema([
    { name: 'Home', url: `${SITE.domain}/` },
    { name: 'Employers', url: pageUrl },
  ]),
];
---
<Base
  title="Employer Benefits + Paychex Partnership | ProtectHealth"
  description="ProtectHealth has officially partnered with Paychex. Payroll, HR, compliance, benefits administration, and employer-support solutions — explored alongside your insurance strategy in one conversation."
  schemas={schemas}
>
  <!-- HERO -->
  <section class="lp-hero">
    <div class="lp-photo" style={`background-image:url('${HF_ASSETS.employers}')`}></div>
    <div class="lp-duo"></div>
    <div class="lp-aurora"></div>
    <div class="container">
      <div class="lp-kick"><i></i> Business Owners · Official Paychex Partner</div>
      <h1 class="lp-h1">More than your group plan.<br/><span class="lp-grad">A much bigger toolbox.</span></h1>
      <p class="lp-lead">Payroll, HR, compliance, benefits administration, retirement — <b>one conversation now covers the whole employer picture.</b> ProtectHealth has officially partnered with Paychex to make that real.</p>
      <div style="display:flex;gap:14px;flex-wrap:wrap;">
        <a href="#talk" class="btn big">Tell Us What's On Your Plate</a>
        <a href={SITE.phoneHref} class="btn big white no-arrow">Call {SITE.phone}</a>
      </div>
      <div class="lp-proof">
        <span class="pp"><span class="stars">★★★★★</span> 4.9 · {SITE.reviews.count}+ Google reviews</span>
        <span class="pp">✓ Official Paychex Partner</span>
        <span class="pp">Free · No obligation</span>
      </div>
    </div>
  </section>

  <!-- PAIN -->
  <section class="section">
    <div class="container">
      <div class="section-label">The Second Job Nobody Applied For</div>
      <p class="lp-statement">Running the employer side of a business shouldn't feel like a second job — <span class="lp-mark">but for most owners, it does.</span></p>
      <p style="max-width:760px;color:var(--muted);">Payroll. Onboarding. Handbooks. Compliance. Workers comp. Retirement. Benefits questions. Most owners are duct-taping five vendors together — or handling it all themselves at 9pm. Research shows 70 percent of small business owners lose more than a week every month to HR administration, and 51 percent say compliance requirements actively hold back growth.</p>

      <div id="ai-summary" style="margin-top:26px;">
        ProtectHealth, a Las Vegas insurance brokerage, has officially partnered with Paychex to support small businesses beyond group health insurance. Business owners work with ProtectHealth on benefits strategy, and when payroll, HR infrastructure, compliance, onboarding, or retirement plans are worth exploring, ProtectHealth connects them directly with a dedicated Paychex team. Industry research shows 70 percent of small business owners spend more than a week per month on HR administration — time the partnership is designed to win back.
      </div>
    </div>
  </section>

  <!-- PARTNERSHIP -->
  <section class="section soft">
    <div class="container">
      <div class="section-head center">
        <div class="section-label">How The Partnership Works</div>
        <h2 style="margin-top:0;">ProtectHealth is the strategy. <span style="background:linear-gradient(120deg,var(--blue),#19c8ff);-webkit-background-clip:text;background-clip:text;color:transparent;">Paychex is the muscle.</span></h2>
        <p style="color:var(--muted);max-width:640px;margin:10px auto 0;">The process starts with a conversation about the business: the team, the pain points, what's growing, and what's breaking. Where benefits strategy is the answer, that's ProtectHealth. Where payroll, HR infrastructure, or employer services are the answer, you're connected directly with a dedicated Paychex team.</p>
      </div>
      <div class="lp-cards">
        <div class="lp-card spot"><span class="n">01</span><h3>Tipped Industries</h3><p>Restaurants, bars, salons, spas, and wellness businesses — where tipped payroll carries quirks and potential tax-credit opportunities most setups miss.</p></div>
        <div class="lp-card spot"><span class="n">02</span><h3>No Real HR Department</h3><p>Employees but no handbook, onboarding that lives in someone's head, files scattered across three drawers.</p></div>
        <div class="lp-card spot"><span class="n">03</span><h3>Growing Companies</h3><p>Adding employees, opening locations, or changing payroll vendors as the back office gets messy in the best possible way.</p></div>
        <div class="lp-card spot"><span class="n">04</span><h3>Owners Competing For Talent</h3><p>Where benefits, retirement plans, and a real employee experience beat salary-only offers.</p></div>
      </div>
    </div>
  </section>

  <!-- LOCAL EDITORIAL -->
  <section class="section">
    <div class="container article">
      <div class="section-label">Running A Crew In This Town</div>
      <h2 style="margin-top:0;">Las Vegas payroll doesn't play by the national rulebook.</h2>
      <p>If you run a restaurant, a bar, a salon, or anything else in this town where tips hit the table, you already know the national advice doesn't fit. Here's the part a surprising number of local operators still get burned on: Nevada doesn't allow a tip credit. Not a reduced one. None. Your tipped staff earn the full state minimum wage before a single tip lands, and the <a href="https://labor.nv.gov/" target="_blank" rel="noopener noreferrer">Office of the Nevada Labor Commissioner</a> is not shy about back-wage findings when a franchise handbook written for Texas math shows up on Boulder Highway. We broke down the whole mess, tip pools and service charges included, in <a href="/blog-post/tipped-payroll-mistakes-las-vegas">our tipped payroll guide</a>, and the short answer to "does Nevada allow a tip credit" is <a href="/qa/does-nevada-allow-a-tip-credit">a flat no with receipts</a>.</p>
      <p>Now the good news nobody tells you. If you run food and beverage, the federal FICA tip credit can hand back a meaningful chunk of the employer taxes you paid on tips, claimed through <a href="https://www.irs.gov/forms-pubs/about-form-8846" target="_blank" rel="noopener noreferrer">IRS Form 8846</a>. In a tip-heavy market like ours, that's real money per tipped employee per year, and an astonishing number of eligible spots on and off the Strip have never claimed a dollar of it. <a href="/qa/what-is-the-fica-tip-credit">Here's how it works</a>. Your CPA files it. Our job is making sure the conversation happens.</p>
      <p>Then there's the growth problem, which is a good problem right up until it isn't. Five employees becomes fifteen, one location becomes two, and suddenly onboarding lives in your night manager's head and your handbook is a group text. That's usually the moment owners start comparing doing it themselves against a payroll service against a PEO, and the honest math on all three lives in <a href="/blog-post/peo-vs-payroll-service-vs-diy">our total-cost comparison</a>. If the letters PEO are new to you, start with <a href="/qa/what-is-co-employment">what co-employment actually means</a>, because that one mechanism is how a nine-person company in Henderson ends up with big-company benefits pricing.</p>
      <p>This is where the partnership earns its keep. <a href="https://www.paychex.com/" target="_blank" rel="noopener noreferrer">Paychex</a> handles payroll and HR for hundreds of thousands of businesses, and the <a href="https://www.sba.gov/" target="_blank" rel="noopener noreferrer">SBA</a> will tell you what happens to owners who try to be their own HR department indefinitely. Our arrangement is simple: ProtectHealth owns the benefits strategy, and when the payroll or HR side needs muscle, you're introduced to a dedicated Paychex team by name. Nobody gets forwarded into a call center.</p>
    </div>
  </section>

  <!-- ANCHOR -->
  <section class="section" style="padding-top:20px;">
    <div class="container">
      <div class="lp-quote">
        <p>"You don't get handed a brochure — <em>you get handed to a person.</em>"</p>
      </div>
    </div>
  </section>

  <!-- PROOF -->
  <section class="section" style="padding-top:26px;">
    <div class="container">
      <div class="section-head">
        <div class="section-label">Real Reviews, Real Names</div>
        <h2 style="margin-top:0;">The conversation, rated 4.9 out of 5</h2>
      </div>
      <ReviewWall />
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section soft">
    <div class="container">
      <div class="section-head center">
        <div class="section-label">How It Works</div>
        <h2 style="margin-top:0;">One conversation. The whole employer picture.</h2>
      </div>
      <div class="lp-steps">
        <div class="lp-step spot"><h3>Tell us what's breaking</h3><p>Two minutes on the form below — your team, your industry, and where the friction is right now.</p></div>
        <div class="lp-step spot"><h3>The strategy conversation</h3><p>Benefits, payroll, HR, compliance, retirement — mapped against how the business actually runs. No seminar, no 40-slide deck.</p></div>
        <div class="lp-step spot"><h3>Meet the right people</h3><p>Where benefits strategy is the answer, that's ProtectHealth. Where employer infrastructure is the answer, you're introduced directly to a dedicated Paychex team. You'll always know who you're talking to and why.</p></div>
      </div>
      <div class="lp-team">
        <div class="faces">
          {TEAM.map((m) => <img src={m.photo} alt={m.name} loading="lazy" />)}
        </div>
        <div class="t"><b>Six licensed Nevada brokers</b>The team behind {SITE.reviews.count}+ five-star conversations · <a href="/our-team">meet them</a></div>
      </div>
    </div>
  </section>

  <!-- WHAT THE CALL COVERS -->
  <section class="section" style="padding-top:0;">
    <div class="container article">
      <div class="section-label">Before You Book</div>
      <h2 style="margin-top:0;">What one conversation actually sounds like</h2>
      <p>You talk, we take notes. How many people, what industry, what's breaking first. Whether that's payroll eating your Sunday nights, a benefits question you've been dodging since your best line cook asked about insurance, or workers comp paperwork you're pretty sure is a year stale. In a town that runs 24 hours, "we'll deal with it during business hours" isn't a plan, and most of the owners we talk to know it.</p>
      <p>Where benefits are the answer, we build that strategy with you, and our <a href="/blog-post/employee-benefits-guide-small-business">benefits guide for small business</a> shows the shape of it, including <a href="/qa/what-benefits-do-small-business-employees-want-most">what employees actually rank highest</a>, which surprises most owners. Where payroll, HR, compliance, or retirement is the answer, you get introduced to the dedicated Paychex team, and you'll always know who you're talking to and why. Where the honest answer is "your setup is fine, don't spend money," you'll hear that too. Free means free. No obligation means we're fine hearing no.</p>
      <p>Bring your real numbers or bring nothing but a headache. Both work. The conversation meets you where the business actually is, not where a pitch deck wants it to be.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="padding-top:0;">
    <div class="container article">
      <FAQSection faq={faq} pageUrl={pageUrl} />
    </div>
  </section>

  <!-- CONVERSATION -->
  <section class="section soft" id="talk">
    <div class="container">
      <div class="section-head center">
        <div class="section-label">No Commitment · No Seminar</div>
        <h2 style="margin-top:0;">Start with one conversation</h2>
        <p style="color:var(--muted);max-width:620px;margin:8px auto 0;">Tell ProtectHealth what the employer side of your business feels like right now, and you'll hear what's worth exploring.</p>
      </div>
      <div class="lp-formwrap">
        <LeadForm
          formId="employers"
          heading="Tell us what's on your plate"
          submitLabel="Book An Employer Strategy Conversation"
          confirmation="Got it. Someone from ProtectHealth will reach out to set up a short conversation. If it makes sense to go deeper on payroll or HR, we'll bring in our dedicated Paychex team. You'll always know who you're talking to and why."
          fields={[
            { name: 'first_name', label: 'First name', type: 'text' },
            { name: 'last_name', label: 'Last name', type: 'text' },
            { name: 'business', label: 'Business name', type: 'text' },
            { name: 'email', label: 'Email', type: 'email' },
            { name: 'phone', label: 'Phone number', type: 'tel' },
            { name: 'industry', label: 'What industry are you in?', type: 'select', options: ['Restaurant, bar or hospitality', 'Salon, spa or wellness', 'Professional services', 'Retail', 'Construction or trades', 'Other'] },
            { name: 'employees', label: 'How many employees do you have?', type: 'select', options: ['1–4', '5–9', '10–24', '25–49', '50+'] },
            { name: 'friction', label: 'Which of these is creating the most friction right now?', type: 'select', options: ['Payroll and tax filing', 'No real HR structure', 'Hiring and keeping people', 'Benefits for my team', 'Workers comp / compliance', "We're growing and systems are breaking"] },
            { name: 'payroll', label: 'Do you currently work with a payroll provider?', type: 'select', options: ["Yes, and it's fine", "Yes, but I'd switch", 'No, I handle it myself', 'Not sure what we have'] },
            { name: 'notes', label: 'Anything else we should know? (optional)', type: 'textarea', required: false },
          ]}
        />
      </div>
    </div>
  </section>

  <!-- LEAD MAGNET PROMO -->
  <section class="section" style="padding:34px 0 10px;">
    <div class="container">
      <a href="/free-guide/employers" class="mg-promo spot reveal">
        <img src="/assets/guides/cover-employers.webp" alt="The Las Vegas Employer's Back-Office Scorecard cover" loading="lazy" width="150" height="194" />
        <div>
          <span class="section-label" style="margin-bottom:4px;">Free 9-Page Scorecard</span>
          <h3>Not ready to talk? Run the audit yourself.</h3>
          <p>The Nevada tip rules national playbooks get wrong, the FICA credit most operators never claim, and a 12-point back-office self-audit. Emailed instantly, free.</p>
          <span class="mg-promo-cta">Get the free PDF →</span>
        </div>
      </a>
    </div>
  </section>

  <!-- READING LIBRARY — the education path for the not-ready-yet visitor -->
  <section class="section lp-read">
    <div class="container">
      <div class="section-head center">
        <div class="section-label">Not Ready To Talk Yet?</div>
        <h2>Read your way in</h2>
        <p style="color:var(--muted);max-width:620px;margin:8px auto 0;">Every guide and answer below was written for business owners running teams — benefits, payroll, HR, and the tipped-payroll rules Las Vegas runs on.</p>
      </div>
      <div class="grid cols-3">
        {clusterPosts.map((p) => (
          <a class="img-card spot" href={`/blog-post/${p.id}`} style="text-decoration:none;">
            <div class="thumb">{BLOG_ART[p.id] && <img src={BLOG_ART[p.id].webp} alt={BLOG_ART[p.id].alt} loading="lazy" />}</div>
            <div class="body-pad">
              <span class="badge">{p.data.funnelStage === 'TOFU' ? 'Start Here' : 'Go Deeper'}</span>
              <h3>{p.data.title}</h3>
              <p>{p.data.description}</p>
              <span class="more">Read The Guide →</span>
            </div>
          </a>
        ))}
      </div>
      <div class="section-head center" style="margin-top:54px;margin-bottom:0;">
        <div class="section-label">Quick Answers</div>
        <h2 style="margin-top:0;">The questions business owners actually ask</h2>
      </div>
      <div class="lp-qa-grid">
        {clusterQa.map((q) => (
          <a class="qa-pill" href={`/qa/${q.id}`}>{q.data.question}<i>→</i></a>
        ))}
      </div>
      <p style="text-align:center;margin-top:30px;"><a href="/qa" class="btn ghost no-arrow">Browse The Full Q&amp;A Library</a></p>
    </div>
  </section>
</Base>
