---
import Base from '../../layouts/Base.astro';
import { SITE, BLOG_ART, breadcrumbSchema } from '../../lib/site';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) =>
  b.data.datePublished.localeCompare(a.data.datePublished)
);
const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: `${SITE.domain}/` },
    { name: 'Blog', url: `${SITE.domain}/blog` },
  ]),
];
---
<Base
  title="Insurance Guides & News | ProtectHealth Blog"
  description="Plain-English guides on Nevada health insurance, self-employed coverage strategy, ICHRA, employer benefits, and more from the ProtectHealth team."
  schemas={schemas}
>
  <section class="hero">
    <div class="container">
      <div class="kicker">Blog / News</div>
      <h1>Guides worth reading before you buy anything</h1>
      <p class="lead">Strategy-first education for Nevadans, self-employed professionals, and business owners.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="grid cols-3">
        {posts.map((p) => (
          <a class="img-card spot" href={`/blog-post/${p.id}`} style="text-decoration:none;">
            {BLOG_ART[p.id] && <div class="thumb"><img src={BLOG_ART[p.id].webp} alt={BLOG_ART[p.id].alt} loading="lazy" /></div>}
            <div class="body-pad">
              <span class="badge">{p.data.category}</span>
              <h3>{p.data.title}</h3>
              <p>{p.data.description}</p>
              <span class="more">Read More →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
