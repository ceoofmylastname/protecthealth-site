---
// BOFU terminus for the ICHRA cluster. Copy from the approved ICHRA Launch Kit.
// v7 journey treatment: hero → pain → four doors → anchor → proof → process → team → FAQ → conversation.
import Base from '../layouts/Base.astro';
import LeadForm from '../components/LeadForm.astro';
import FAQSection from '../components/FAQSection.astro';
import { SITE, ORG_ID, TEAM, HF_ASSETS, BLOG_ART, breadcrumbSchema, speakableSchema } from '../lib/site';
import { GOOGLE_REVIEWS } from '../lib/reviews';
import { getCollection } from 'astro:content';

const pageUrl = `${SITE.domain}/self-employed`;

// Reading library: every ICHRA-cluster post + Q&A, TOFU first (auto-updates as content grows)
const clusterPosts = (await getCollection('blog'))
  .filter((p) => p.data.cluster === 'ichra')
  .sort((a, b) => (a.data.funnelStage === b.data.funnelStage ? 0 : a.data.funnelStage === 'TOFU' ? -1 : 1));
const clusterQa = (await getCollection('qa'))
  .filter((q) => q.data.cluster === 'ichra')
  .sort((a, b) => a.data.question.localeCompare(b.data.question));
const proof = ['Yvette Auger', 'Amber Gunn (Niel)', 'Stephen Kuo']
  .map((n) => GOOGLE_REVIEWS.find((r) => r.name === n))
  .filter(Boolean);

const faq = [
  { q: 'Does every self-employed person qualify for an ICHRA or Section 105 arrangement?', a: 'No. Eligibility for tax-advantaged health-benefit structures depends on business structure, income, and household situation. A ProtectHealth strategy conversation maps which options actually fit a specific situation.' },
  { q: 'Is a ProtectHealth strategy conversation a sales appointment?', a: 'No. The 20-minute conversation walks through business structure, household needs, and available options — individual coverage, PPO access, small-group opportunities, or tax-advantaged structures. If existing coverage is already right, ProtectHealth says so.' },
  { q: 'Why does ProtectHealth recommend talking to a tax professional?', a: 'ProtectHealth brokers are insurance professionals, not tax professionals. When business or tax structure becomes part of the discussion, a brief conversation with a licensed tax professional is the responsible next step.' },
  { q: 'What should a Realtor bring to a strategy conversation?', a: 'A rough idea of household income, current plan details if coverage exists, and how the business is structured — sole proprietor, LLC, or S-corp. Not sure about structure is a fine answer; that is part of the conversation.' },
  { q: 'Does ProtectHealth only work with Realtors?', a: 'No. ProtectHealth works with Realtors, 1099 contractors, freelancers, and self-employed professionals across Nevada, plus small businesses building employee benefits.' },
];

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Self-Employed Health Coverage Strategy — ProtectHealth',
    description: 'Health coverage strategy for Realtors, 1099 contractors, and self-employed professionals in Nevada: individual coverage, genuine PPO options, small-group opportunities, and tax-advantaged health-benefit structures.',
    provider: { '@id': ORG_ID },
    areaServed: { '@type': 'State', name: 'Nevada' },
    url: pageUrl,
  },
  speakableSchema(pageUrl),
  breadcrumbSchema([
    { name: 'Home', url: `${SITE.domain}/` },
    { name: 'Self-Employed Strategy', url: pageUrl },
  ]),
];
---
<Base
  title="Health Coverage Strategy For Realtors & 1099s | ProtectHealth"
  description="Self-employed? Your health coverage should be built around your business — not somebody's product. Realtors, 1099 contractors, and self-employed professionals may have options nobody ever explained."
  schemas={schemas}
>
  <!-- HERO -->
  <section class="lp-hero">
    <div class="lp-photo" style={`background-image:url('${HF_ASSETS.realtor}')`}></div>
    <div class="lp-duo"></div>
    <div class="lp-aurora"></div>
    <div class="container">
      <div class="lp-kick"><i></i> Realtors · 1099 Contractors · Self-Employed</div>
      <h1 class="lp-h1">Built around your business.<br/><span class="lp-grad">Not somebody's product.</span></h1>
      <p class="lp-lead">Individual coverage, genuine PPO access, small-group opportunities, tax-advantaged structures — <b>most self-employed professionals have never had a single one of them properly explained.</b> That's what ProtectHealth does.</p>
      <div style="display:flex;gap:14px;flex-wrap:wrap;">
        <a href="#talk" class="btn big">Let's Talk Through Your Situation</a>
        <a href={SITE.phoneHref} class="btn big white no-arrow">Call {SITE.phone}</a>
      </div>
      <div class="lp-proof">
        <span class="pp"><span class="stars">★★★★★</span> 4.9 · {SITE.reviews.count}+ Google reviews</span>
        <span class="pp">20 minutes · $0 · No pitch</span>
        <span class="pp">Las Vegas · All of Nevada</span>
      </div>
    </div>
  </section>

  <!-- PAIN / TRUTH -->
  <section class="section">
    <div class="container">
      <div class="section-label">The Part Nobody Explains</div>
      <p class="lp-statement">Premiums and deductibles are the beginning of the conversation — <span class="lp-mark">not the end of it.</span></p>
      <p style="max-width:760px;color:var(--muted);">Age, household income, tax-credit eligibility, provider networks, prescriptions, and total financial exposure decide what "good coverage" actually looks like. Two Realtors at the same brokerage with the same premium can have completely different coverage quality. NAR data shows 10 to 15 percent of Realtors carry no coverage at all — usually because nobody ever explained the options, not because options don't exist.</p>

      <div id="ai-summary" style="margin-top:26px;">
        ProtectHealth helps Realtors, 1099 contractors, and self-employed professionals in Nevada build health coverage strategies around how their business is structured. Depending on structure, options may include individual marketplace coverage, genuine PPO access, small-group plans, or tax-advantaged health-benefit structures such as ICHRA and Section 105 arrangements. National Association of Realtors data shows 10 to 15 percent of Realtors remain uninsured — usually because nobody ever explained the options, not because options don't exist.
      </div>
    </div>
  </section>

  <!-- FOUR DOORS -->
  <section class="section soft">
    <div class="container">
      <div class="section-head center">
        <div class="section-label">Your Possible Doors</div>
        <h2 style="margin-top:0;">Four paths. <span class="lp-mark" style="background:linear-gradient(120deg,var(--blue),#19c8ff);-webkit-background-clip:text;background-clip:text;color:transparent;">One of them fits.</span></h2>
        <p style="color:var(--muted);">Which doors are open depends on how your business is structured. That's exactly what the conversation figures out.</p>
      </div>
      <div class="lp-cards">
        <div class="lp-card spot"><span class="n">01</span><h3>Individual Coverage, Done Right</h3><p>Marketplace plans with the subsidy math actually run — net self-employment income, tax credits, and the deduction most 1099s never claim.</p></div>
        <div class="lp-card spot"><span class="n">02</span><h3>Genuine PPO Access</h3><p>Real PPO options with real networks — checked against your actual doctors before anything gets signed.</p></div>
        <div class="lp-card spot"><span class="n">03</span><h3>Small-Group Opportunities</h3><p>Some business setups unlock group coverage most self-employed people assume they can't have.</p></div>
        <div class="lp-card spot"><span class="n">04</span><h3>Tax-Advantaged Structures</h3><p>ICHRA and Section 105 arrangements — small-employer ICHRA adoption grew 52% last year. Eligibility depends on structure, which is the whole point of the conversation.</p></div>
      </div>
      <p style="text-align:center;color:var(--muted);font-size:0.92rem;margin-top:22px;">Not every option fits every person. That's the point of having a strategy.</p>
    </div>
  </section>

  <!-- LOCAL EDITORIAL -->
  <section class="section">
    <div class="container article">
      <div class="section-label">The Vegas Version Of Self-Employed</div>
      <h2 style="margin-top:0;">Your income closes in escrow. Your insurance thinks you get a paycheck.</h2>
      <p>Here's the thing about being self-employed in Las Vegas. Your income doesn't show up in tidy biweekly deposits. It shows up when a deal closes, when a client pays, when a busy season hits. Three closings in March, nothing in April, and somewhere in the middle of that you're supposed to guess what you'll earn this year, because that guess is exactly what <a href="https://www.nevadahealthlink.com/" target="_blank" rel="noopener noreferrer">Nevada Health Link</a> uses to calculate your premium tax credit.</p>
      <p>Guess low and you pay some of that credit back at tax time. Guess high and you leave money on the table every single month. Most agents and contractors we sit down with have never had anyone walk them through <a href="/qa/what-income-counts-for-aca-subsidies">what income actually counts</a>, or the fact that the math runs on your net self-employment income after expenses, not the gross number on your 1099. We wrote a whole plain-English breakdown of <a href="/blog-post/aca-premium-tax-credits-explained">how the premium tax credit really works</a> because we got tired of watching people overpay for coverage they could have gotten help with.</p>
      <p>Then there's the deduction almost nobody claims correctly. If you qualify, health insurance premiums come off your income above the line. The IRS lays it out in their <a href="https://www.irs.gov/businesses/small-businesses-self-employed/self-employed-individuals-tax-center" target="_blank" rel="noopener noreferrer">Self-Employed Individuals Tax Center</a>, and the short version is that a lot of 1099 professionals in this valley are effectively paying 20 to 30 percent more for coverage than they need to. Whether you can claim it depends on your situation, which is a conversation for your tax professional, and yes, <a href="/qa/is-self-employed-health-insurance-tax-deductible">we wrote up that answer too</a>.</p>
      <p>And the structures. ICHRA and Section 105 arrangements have been growing for five straight years nationally. The <a href="https://www.hracouncil.org/" target="_blank" rel="noopener noreferrer">HRA Council</a> tracks the adoption data, and the growth among small employers has been the fastest of all. If you've never heard those words before, start with <a href="/blog-post/what-is-an-ichra">our plain-English ICHRA guide</a>, and if you're an S-corp owner wondering whether this applies to you, <a href="/qa/can-an-s-corp-owner-use-an-ichra">that answer has some fine print worth reading</a> before anyone sells you anything.</p>
      <p>One more thing, because this is Las Vegas and this industry has its share of characters. Any broker you talk to, us included, should be verifiable through the <a href="https://doi.nv.gov/" target="_blank" rel="noopener noreferrer">Nevada Division of Insurance</a>. Look us up. We'll wait.</p>
    </div>
  </section>

  <!-- ANCHOR -->
  <section class="section" style="padding-top:20px;">
    <div class="container">
      <div class="lp-quote">
        <p>"The product should serve the strategy — <em>not become the strategy.</em>"</p>
      </div>
    </div>
  </section>

  <!-- PROOF -->
  <section class="section" style="padding-top:26px;">
    <div class="container">
      <div class="section-head">
        <div class="section-label">Real Reviews, Real Names</div>
        <h2 style="margin-top:0;">Self-employed Nevadans have had this conversation</h2>
      </div>
      <div class="lp-reviews">
        {proof.map((r) => (
          <div class="lp-review spot">
            <span class="stars">★★★★★</span>
            <p>{r.text}</p>
            <div class="who">
              {r.photo ? <img src={r.photo} alt="" loading="lazy" referrerpolicy="no-referrer" onerror="this.remove()" /> : <span class="av">{r.name.charAt(0)}</span>}
              <span><b>{r.name}</b> · {r.date} · Google</span>
            </div>
          </div>
        ))}
      </div>
      <p style="font-size:0.88rem;color:var(--muted);margin-top:16px;">Pulled word for word from ProtectHealth's Google listing — <a href={SITE.reviews.url} target="_blank" rel="noopener noreferrer">read all {SITE.reviews.count}+</a>.</p>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section soft">
    <div class="container">
      <div class="section-head center">
        <div class="section-label">How It Works</div>
        <h2 style="margin-top:0;">20 minutes, start to clarity</h2>
      </div>
      <div class="lp-steps">
        <div class="lp-step spot"><h3>Tell us your situation</h3><p>Two minutes on the form below — how you work, how the business is set up, what you have now.</p></div>
        <div class="lp-step spot"><h3>The strategy conversation</h3><p>Structure, doctors, prescriptions, subsidy math, total exposure. Which doors are open for you, which aren't, and why.</p></div>
        <div class="lp-step spot"><h3>Walk away with the map</h3><p>Zero dollars, zero obligation. If what you already have is right, ProtectHealth tells you that too. When tax structure enters the picture, a licensed tax professional joins the conversation — we're insurance nerds, not tax professionals.</p></div>
      </div>
      <div class="lp-team">
        <div class="faces">
          {TEAM.map((m) => <img src={m.photo} alt={m.name} loading="lazy" />)}
        </div>
        <div class="t"><b>Six licensed Nevada brokers</b>The team behind {SITE.reviews.count}+ five-star conversations · <a href="/our-team">meet them</a></div>
      </div>
    </div>
  </section>

  <!-- WHAT THE CALL COVERS -->
  <section class="section" style="padding-top:0;">
    <div class="container article">
      <div class="section-label">Before You Book</div>
      <h2 style="margin-top:0;">What actually happens in those 20 minutes</h2>
      <p>No slideshow. No script. Someone from the team, all six of us are licensed here in Nevada and based off West Charleston, asks how your business is set up and what your year actually looks like. Sole proprietor, LLC, S-corp, or "my CPA handles it and I sign things." All normal answers.</p>
      <p>Then we check the things that decide whether coverage is good or just cheap. Which doctors you'd hate to lose. What prescriptions you fill every month. Whether your income qualifies you for help through the marketplace, and whether the way you file taxes opens any of the doors above. If you're a Realtor, we'll probably talk about what happens in a year where you close eight deals versus a year where you close twenty, because your coverage has to survive both. Our <a href="/blog-post/realtor-health-insurance-guide">Realtor coverage guide</a> covers the version of this conversation we've had a few hundred times, and if you're driving for three apps or freelancing across state lines, the <a href="/blog-post/health-insurance-for-freelancers-and-gig-workers">freelancer and gig worker breakdown</a> is the better read.</p>
      <p>Sometimes the answer is that what you already have is right. We say that out loud when it's true. It costs us the sale and it's still the right answer, because you'll remember who told you the truth, and Las Vegas is a small town wearing a big city's clothes.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="padding-top:0;">
    <div class="container article">
      <FAQSection faq={faq} pageUrl={pageUrl} />
    </div>
  </section>

  <!-- CONVERSATION -->
  <section class="section soft" id="talk">
    <div class="container">
      <div class="section-head center">
        <div class="section-label">No Quote-Blasting · No Pressure</div>
        <h2 style="margin-top:0;">Book your strategy conversation</h2>
        <p style="color:var(--muted);max-width:600px;margin:8px auto 0;">Walk away knowing which options fit your structure, which don't, and what questions to ask next.</p>
      </div>
      <div class="lp-formwrap">
        <LeadForm
          formId="ichra"
          heading="Tell us about your situation"
          submitLabel="Book A Strategy Conversation"
          confirmation="You're booked. Quick heads-up on how we work: this is a strategy conversation, not a sales appointment. Have a rough idea of your household income and current plan details handy if you can."
          fields={[
            { name: 'name', label: 'Full name', type: 'text' },
            { name: 'email', label: 'Email', type: 'email' },
            { name: 'phone', label: 'Phone number', type: 'tel' },
            { name: 'profile', label: 'Which best describes you?', type: 'select', options: ['Realtor', '1099 contractor', 'Self-employed', 'Small business owner with a team', 'Other'] },
            { name: 'structure', label: 'How is your business currently structured?', type: 'select', options: ['Sole proprietor', 'LLC', 'S-corp', 'Not sure', 'Prefer to discuss'] },
            { name: 'coverage', label: "What's your current coverage situation?", type: 'select', options: ['Marketplace plan', "Spouse's plan", 'Group plan', 'No coverage right now', 'Not sure what I have'] },
            { name: 'priority', label: 'What matters most to you in this conversation?', type: 'select', options: ['Keeping my doctors', 'Lowering total cost', 'Understanding my options', 'Covering my family', 'Exploring options for my team'] },
            { name: 'notes', label: 'Anything you want us to know before we talk? (optional)', type: 'textarea', required: false },
          ]}
        />
      </div>
    </div>
  </section>

  <!-- READING LIBRARY — the education path for the not-ready-yet visitor -->
  <section class="section lp-read">
    <div class="container">
      <div class="section-head center">
        <div class="section-label">Not Ready To Talk Yet?</div>
        <h2>Read your way in</h2>
        <p style="color:var(--muted);max-width:600px;margin:8px auto 0;">Every guide and answer below was written for Realtors, 1099s, and the self-employed. Start anywhere — the strategy will make sense by the end.</p>
      </div>
      <div class="grid cols-3">
        {clusterPosts.map((p) => (
          <a class="img-card spot" href={`/blog-post/${p.id}`} style="text-decoration:none;">
            <div class="thumb">{BLOG_ART[p.id] && <img src={BLOG_ART[p.id].webp} alt={BLOG_ART[p.id].alt} loading="lazy" />}</div>
            <div class="body-pad">
              <span class="badge">{p.data.funnelStage === 'TOFU' ? 'Start Here' : 'Go Deeper'}</span>
              <h3>{p.data.title}</h3>
              <p>{p.data.description}</p>
              <span class="more">Read The Guide →</span>
            </div>
          </a>
        ))}
      </div>
      <div class="section-head center" style="margin-top:54px;margin-bottom:0;">
        <div class="section-label">Quick Answers</div>
        <h2 style="margin-top:0;">The questions self-employed Nevadans actually ask</h2>
      </div>
      <div class="lp-qa-grid">
        {clusterQa.map((q) => (
          <a class="qa-pill" href={`/qa/${q.id}`}>{q.data.question}<i>→</i></a>
        ))}
      </div>
      <p style="text-align:center;margin-top:30px;"><a href="/qa" class="btn ghost no-arrow">Browse The Full Q&amp;A Library</a></p>
    </div>
  </section>
</Base>
